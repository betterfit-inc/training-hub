{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "next": true,
  "vitest": true,
  "entry": ["scripts/*.ts", "e2e/**/*.ts"],
  "project": ["src/**/*.{ts,tsx}", "scripts/**/*.ts", "e2e/**/*.ts"],
  "ignoreExportsUsedInFile": true,
  "ignore": ["src/components/ui/**", "src/lib/sports.ts", "src/lib/db.ts", "src/lib/telemetry.ts"],
  "ignoreDependencies": ["shadcn", "tw-animate-css", "tailwindcss"]
}
