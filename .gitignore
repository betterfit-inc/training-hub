# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# local data: SQLite database and uploaded shoe photos
/data/

# playwright e2e
/test-results/
/playwright-report/
/playwright/.cache/
/data/e2e.db*
/e2e/.auth/

# scratch space for validation scripts and sub-agent briefs (never committed)
/scratchpad/

# garmin sync service (Python): local venv, bytecode, and the local setup
# helper (holds the ingest secret + creds — must never be committed)
services/garmin-sync/.venv/
**/__pycache__/
services/garmin-sync/*.local.sh

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
