# Strava API application credentials.
# Create an app at https://www.strava.com/settings/api
# and set its Authorization Callback Domain to: localhost (or your deployed domain)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# Database — dev and prod are split, keep them that way.
# LOCAL DEVELOPMENT: leave both empty. The app uses the local file data/app.db.
# Do NOT point these at the production Turso database from your machine: local dev
# must never target prod. Sharing one DB is the risk this split closes.
# PRODUCTION (Vercel) sets its own values:
#   TURSO_DATABASE_URL=libsql://training-hub-<org>.turso.io
#   TURSO_AUTH_TOKEN=<token from: turso db tokens create training-hub>
# The seed/backfill write scripts refuse to run against a remote (non-file:) URL as
# a safety net. Override only when you truly mean to with ALLOW_REMOTE_DB=1.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Shoe photos. Leave empty locally (files go to data/uploads/).
# On Vercel, create a Blob store and this token is injected automatically.
BLOB_READ_WRITE_TOKEN=

# Auth boundary (T1.6) — single-owner password login.
# Leave BOTH empty locally and auth is DISABLED (the app behaves as before,
# every mutating action is allowed). PRODUCTION MUST set BOTH to enforce the
# gate: AUTH_PASSWORD is the owner login password; AUTH_SECRET signs the session
# cookie (use a long random value, e.g. `openssl rand -hex 32`). Rotating
# AUTH_SECRET invalidates all existing sessions.
AUTH_PASSWORD=
AUTH_SECRET=

# Health ingest (source-agnostic daily health/readiness layer).
# Shared machine token for POST /api/health/ingest. The standalone sync service
# (services/garmin-sync, a GitHub Action) sends it as `Authorization: Bearer
# <token>`; the app checks it constant-time. Leave empty locally and the ingest
# endpoint is CLOSED (503) — manual entry still works without it. In production
# set the SAME long random value here and in the sync service's secret store
# (e.g. `openssl rand -hex 32`). This never authenticates a browser user.
HEALTH_INGEST_SECRET=
