{
  "name": "training-hub",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:unit": "vitest run",
    "deadcode": "knip",
    "cycles": "madge --circular --ts-config tsconfig.json --extensions ts,tsx src",
    "verify": "npm run typecheck && npm run lint && npm run format:check && npm run test:unit && npm run deadcode && npm run cycles",
    "seed": "tsx scripts/seed.ts",
    "seed:clear": "tsx scripts/seed.ts --clear",
    "backfill:load": "tsx scripts/backfill-load.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.113.0",
    "@libsql/client": "^0.17.4",
    "@vercel/blob": "^2.6.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.25.0",
    "next": "16.2.10",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.6.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.13.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "knip": "^6.29.0",
    "madge": "^8.0.0",
    "prettier": "^3.9.6",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
